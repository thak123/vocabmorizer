# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# Admin bootstrap account (bypasses the user table)
# Login with username "admin" and this password.
ADMIN_PASSWORD=change-me

# Database (defaults to data/vocabmorizer.db if not set)
# DATABASE_URL=sqlite:///data/vocabmorizer.db

# Google OAuth (Phase 9 — leave blank until then)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Cloud backup — S3-compatible (Phase 8 — leave blank until then)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
